//
// Chrono configuration header file
//
// Automatically created during CMake configuration.
//
// =============================================================================

#ifndef CH_CONFIG_H
#define CH_CONFIG_H

// -----------------------------------------------------------------------------
// Macros specifying enabled Chrono modules
// -----------------------------------------------------------------------------

// If module CASCADE was enabled, define CHRONO_CASCADE
@CHRONO_CASCADE@

// If module IRRLICHT was enabled, define CHRONO_IRRLICHT
@CHRONO_IRRLICHT@

// If module VSG was enabled, define CHRONO_VSG
@CHRONO_VSG@

// If module MATLAB was enabled, define CHRONO_MATLAB
@CHRONO_MATLAB@

// If module PARDISO_MKL was enabled, define CHRONO_PARDISO_MKL
@CHRONO_PARDISO_MKL@

// If module MUMPS was enabled, define CHRONO_MUMPS
@CHRONO_MUMPS@

// If module PARSERS was enabled, define CHRONO_PARSERS
@CHRONO_PARSERS@

// If module MULTICORE was enabled, define CHRONO_MULTICORE
@CHRONO_MULTICORE@

// If module POSTPROCESS was enabled, define CHRONO_POSTPROCESS
@CHRONO_POSTPROCESS@

// If module PYTHON was enabled, define CHRONO_PYTHON
@CHRONO_PYTHON@

// If module VEHICLE was enabled, define CHRONO_VEHICLE
@CHRONO_VEHICLE@

// If module FSI was enabled, define CHRONO_FSI
@CHRONO_FSI@

// If FSI_SPH module was enabled, define CHRONO_FSI_SPH
@CHRONO_FSI_SPH@

// If FSI_TDPF module was enabled, define CHRONO_FSI_TDPF
@CHRONO_FSI_TDPF@

// If module DEM was enabled, define CHRONO_DEM
@CHRONO_DEM@

// If module SYNCHRONO was enabled, define CHRONO_SYNCHRONO
@CHRONO_SYNCHRONO@

// If module SENSOR was enabled, define CHRONO_SENSOR
@CHRONO_SENSOR@

// If module ROS was enabled, define CHRONO_ROS
@CHRONO_ROS@

// If module MODAL was enabled, define CHRONO_MODAL
@CHRONO_MODAL@

// If module FMI was enabled, define CHRONO_FMI
@CHRONO_FMI@

// -----------------------------------------------------------------------------
// C++ standard support
// -----------------------------------------------------------------------------

// If Chrono was built with C++17 support, define CHRONO_HAS_CXX17
@CHRONO_HAS_CXX17@

// -----------------------------------------------------------------------------
// GnuPlot
// -----------------------------------------------------------------------------

// If GnuPlot was found, define CHRONO_HAS_GNUPLOT
@CHRONO_HAS_GNUPLOT@

// -----------------------------------------------------------------------------
// OpenMP settings
// -----------------------------------------------------------------------------

// If OpenMP is found the following define is set, define CHRONO_OMP_FOUND and
// set the highest OpenMP version supported, one of:
//   #define CHRONO_OMP_VERSION "2.0"
//   #define CHRONO_OMP_VERSION "3.0"
//   #define CHRONO_OMP_VERSION "4.0"
// define one or more of the following, as appropriate
//   #define CHRONO_OMP_20
//   #define CHRONO_OMP_30
//   #define CHRONO_OMP_40
@CHRONO_OMP_FOUND@
@CHRONO_OMP_VERSION@
@CHRONO_OMP_20@
@CHRONO_OMP_30@
@CHRONO_OMP_40@

// If OpenMP support was enabled, define CHRONO_OPENMP_ENABLED
@CHRONO_OPENMP_ENABLED@

// -----------------------------------------------------------------------------

// If SSE support was found, define CHRONO_HAS_SSE and
// set the SSE level support, one of the following
//   #define CHRONO_SSE_LEVEL "1.0"
//   #define CHRONO_SSE_LEVEL "2.0"
//   #define CHRONO_SSE_LEVEL "3.0"
//   #define CHRONO_SSE_LEVEL "4.1"
//   #define CHRONO_SSE_LEVEL "4.2"
// define one or more of the following, as appropriate
//   #define CHRONO_SSE_1.0
//   #define CHRONO_SSE_2.0
//   #define CHRONO_SSE_3.0
//   #define CHRONO_SSE_4.1
//   #define CHRONO_SSE_4.2
@CHRONO_HAS_SSE@
@CHRONO_SSE_LEVEL@
@CHRONO_SSE_1_0@
@CHRONO_SSE_2_0@
@CHRONO_SSE_3_0@
@CHRONO_SSE_4_1@
@CHRONO_SSE_4_2@

// -----------------------------------------------------------------------------

// If AVX support was found, define CHRONO_HAS_AVX and
// set the SSE level support, one of the following
//   #define CHRONO_AVX_LEVEL "1.0"
//   #define CHRONO_AVX_LEVEL "2.0"
// define one or more of the following, as appropriate
//   #define CHRONO_AVX_1.0
//   #define CHRONO_AVX_2.0
@CHRONO_HAS_AVX@
@CHRONO_AVX_LEVEL@
@CHRONO_AVX_1_0@
@CHRONO_AVX_2_0@

// -----------------------------------------------------------------------------

// If NEON support was found, define CHRONO_HAS_NEON
@CHRONO_HAS_NEON@

// -----------------------------------------------------------------------------

// If FMA support was found, define CHRONO_HAS_FMA
@CHRONO_HAS_FMA@

// -----------------------------------------------------------------------------

// Use SIMD if available, define CHRONO_SIMD_ENABLED
@CHRONO_SIMD_ENABLED@

// -----------------------------------------------------------------------------

// If HDF5 was found, define CHRONO_HAS_HDF5
@CHRONO_HAS_HDF5@

// -----------------------------------------------------------------------------

// If YAML parser support is available, define CHRONO_HAS_YAML
@CHRONO_HAS_YAML@

// -----------------------------------------------------------------------------

// If CUDA is available, define CHRONO_HAS_CUDA and set CUDA version
@CHRONO_HAS_CUDA@
@CHRONO_CUDA_VERSION@

// If HIP is available, define CHRONO_HAS_HIP and set HIP/ROCm version
@CHRONO_HAS_HIP@
@CHRONO_HIP_VERSION@

// If THRUST is available, define CHRONO_HAS_THRUST and set Thrust version
@CHRONO_HAS_THRUST@
@CHRONO_THRUST_VERSION@

// If neither CUDA nor HIP is available, force Thrust to always use the OMP backend
#if !defined(CHRONO_HAS_CUDA) && !defined(CHRONO_HAS_HIP)
  #ifndef THRUST_DEVICE_SYSTEM
    #define THRUST_DEVICE_SYSTEM THRUST_DEVICE_SYSTEM_OMP
  #endif
#endif

// -----------------------------------------------------------------------------

// If Google Test and/or Benchmark are enabled and available, define CHRONO_HAS_GTEST
// and/or CHRONO_HAS_GBENCHMARK
@CHRONO_HAS_GTEST@
@CHRONO_HAS_GBENCHMARK@

// -----------------------------------------------------------------------------

// If the Chrono multicore collision detection is available, define CHRONO_COLLISION
@CHRONO_COLLISION@

// Always use double in custom multicore collision detection
#define USE_COLLISION_DOUBLE

// -----------------------------------------------------------------------------

// Length of the path to the Chrono source directory
#define SOURCE_PATH_SIZE @SOURCE_PATH_SIZE@

#endif
